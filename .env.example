# Active environment: dev | staging | prod
ENV=staging

# Override base URL (optional; falls back to config/environments/*.yaml)
# BASE_URL=https://staging.example.com

# Browser settings
HEADLESS=true
BROWSER=chromium
SLOW_MO=0
DEFAULT_TIMEOUT=15000

# Parallel workers (local runs; CI uses pytest-xdist -n auto)
# PYTEST_XDIST_WORKER_COUNT=4
